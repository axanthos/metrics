		<properties node_id="14" format="literal">{'associationBias': 'none', 'autoSend': True, 'colDelimiter_idx': 0, 'controlAreaVisible': True, 'conversionType': 'association matrix', 'convert': False, 'displayAdvancedSettings': False, 'exportEncoding': 'utf-8', 'includeOrangeHeaders': False, 'lastLocation': '.', 'normalize': False, 'normalizeMode': 'rows', 'normalizeType': 'l1', 'reformat': False, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x02\x00\x00\x00\x00\x02\x82\x00\x00\x01d\x00\x00\x04\x07\x00\x00\x02y\x00\x00\x02\x86\x00\x00\x01{\x00\x00\x04\x03\x00\x00\x02u\x00\x00\x00\x00\x00\x00\x00\x00\x06\x90', 'sortCols': False, 'sortColsReverse': False, 'sortRows': False, 'sortRowsReverse': False, 'transpose': False, 'unweighted': False, 'uuid': 'd4ffdb33-d998-4ce0-981e-41b41ebf8e85', '__version__': 1, '_TextableUtils_settings_version__': (0, 19)}</properties>
		<properties node_id="15" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x014\x00\x00\x00\xfa\x00\x00\x05\x81\x00\x00\x03p\x00\x00\x014\x00\x00\x01\x19\x00\x00\x05\x81\x00\x00\x03p\x00\x00\x00\x00\x00\x00\x00\x00\x06\x90\x00\x00\x014\x00\x00\x01\x19\x00\x00\x05\x81\x00\x00\x03p', 'scriptLibrary': [], 'scriptText': 'from LTTL.TableThread import Table\n\n\nif in_object == None:\n    out_object = None\n\nelse:  \n    row_ids = list()\n    col_ids = ["verse", "structure", "metric"]\n    values = dict()\n    for segment in in_object:\n        ref, _, verse, structure, metric = segment.get_content().split("\\t")\n        row_ids.append(ref)\n        values[(ref, "verse")] = verse\n        values[(ref, "structure")] = structure\n        values[(ref, "metric")] = metric\n    header_row_id = \'variable\'\n    header_row_type = \'string\'\n    header_col_id = \'ref\'\n    header_col_type = \'string\'\n    col_type = dict((k, \'string\') for k in col_ids)\n    out_object = Table(\n        row_ids,\n        col_ids,\n        values,\n        header_row_id,\n        header_row_type,\n        header_col_id,\n        header_col_type,\n        col_type,\n    )\n', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x01\xad\x00\x00\x00\x86\x01\x00\x00\x00\x05\x01\x00\x00\x00\x02\x01', 'vimModeEnabled': False, '__version__': 2}</properties>
